<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DiplomObsAlarm.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:DiplomObsAlarm"
    Title="AlarmObs">

    <!-- Скрытые маршруты (не в меню) -->
    <ShellContent
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage"
        FlyoutItemIsVisible="False" />

    <ShellContent
        ContentTemplate="{DataTemplate local:UserEnterPage}"
        Route="UserEnterPage"
        FlyoutItemIsVisible="False" />

    <ShellContent
        ContentTemplate="{DataTemplate local:AdminEnterPage}"
        Route="AdminEnterPage"
        FlyoutItemIsVisible="False" />

    <ShellContent
        ContentTemplate="{DataTemplate local:AdminPanelPage}"
        Route="AdminPanelPage"
        FlyoutItemIsVisible="False" />

</Shell>
