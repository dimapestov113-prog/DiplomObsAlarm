<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DiplomObsAlarm.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:DiplomObsAlarm"
    FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">   
    <!--  FlyoutBehavior="Disabled" отключить адидас хуйню -->
    <!-- Скрытые маршруты (не в меню) -->
    

    <ShellContent
        ContentTemplate="{DataTemplate local:AdminEnterPage}"
        Route="AdminEnterPage"
        FlyoutItemIsVisible="False" />

    <ShellContent
        ContentTemplate="{DataTemplate local:AdminPanelPage}"
        Route="AdminPanelPage"
        FlyoutItemIsVisible="False" />

    <ShellContent
        ContentTemplate="{DataTemplate local:UserPanelPage}"
        Route="UserPanelPage"
        FlyoutItemIsVisible="False" />
</Shell>
