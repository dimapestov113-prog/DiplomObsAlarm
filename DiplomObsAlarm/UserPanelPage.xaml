<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DiplomObsAlarm.UserPanelPage"
             Title="Панель пользователя"
             BackgroundColor="White">

    <Grid RowDefinitions="auto,*,auto" Padding="20">

        <!-- Заголовок и информация о пользователе -->
        <VerticalStackLayout Grid.Row="0" Spacing="15" Margin="0,0,0,20">

            <Label Text="Панель пользователя" 
                   FontSize="24" 
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="Black"/>

            <!-- Карточка пользователя -->
            <Border Stroke="Gray" 
                    StrokeThickness="1" 
                    StrokeShape="RoundRectangle 10"
                    Padding="15"
                    BackgroundColor="White">
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="LblLogin" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           TextColor="Black"/>
                    <Label x:Name="LblPhone" 
                           FontSize="14" 
                           TextColor="Gray"/>
                    <Label x:Name="LblRoom" 
                           FontSize="14" 
                           TextColor="Gray"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <!-- Основная область -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="15">

                <!-- Индикатор загрузки -->
                <ActivityIndicator x:Name="ActivityIndicator" 
                                   IsRunning="True" 
                                   IsVisible="True"
                                   Color="Gray"
                                   HorizontalOptions="Center"/>

                <!-- Статус ожидания -->
                <Label x:Name="LblStatus" 
                       Text="Ожидание тревог..." 
                       FontSize="18" 
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="Gray"/>

                <!-- Карточка тревоги -->
                <Border x:Name="AlertCard" 
                        Stroke="Red" 
                        StrokeThickness="2" 
                        StrokeShape="RoundRectangle 15"
                        Padding="20"
                        BackgroundColor="WhiteSmoke"
                        IsVisible="False">

                    <VerticalStackLayout Spacing="15">

                        <!-- Иконка тревоги -->
                        <Image Source="alarm.png" 
                               WidthRequest="80" 
                               HeightRequest="80"
                               HorizontalOptions="Center"/>

                        <!-- Тип тревоги -->
                        <Label x:Name="LblAlertType" 
                               FontSize="22" 
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="Red"
                               HorizontalTextAlignment="Center"/>

                        <!-- Время начала -->
                        <Label x:Name="LblAlertTime" 
                               FontSize="14" 
                               HorizontalOptions="Center"
                               TextColor="Gray"/>

                        <!-- Статус активности -->
                        <Label x:Name="LblAlertStatus" 
                               FontSize="14" 
                               HorizontalOptions="Center"
                               TextColor="Orange"
                               IsVisible="False"/>

                        <!-- Сообщение -->
                        <Label Text="ВНИМАНИЕ!&#10;&#10;Произошла чрезвычайная ситуация!&#10;&#10;Следуйте инструкциям администрации!"
                               FontSize="16"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               TextColor="Red"/>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Кнопки -->
        <VerticalStackLayout Grid.Row="2" Spacing="10" Margin="0,20,0,0">

            <!-- Кнопка отключения тревоги -->
            <Button x:Name="BtnDismiss" 
                    Text="Отключить уведомление"
                    BackgroundColor="Orange"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"
                    IsVisible="False"
                    HorizontalOptions="Center"
                    WidthRequest="250"/>

            <!-- Кнопка выхода -->
            <Button Text="Выйти"
                    BackgroundColor="LightGray"
                    TextColor="Black"
                    CornerRadius="8"
                    HeightRequest="45"
                    HorizontalOptions="Center"
                    WidthRequest="150"
                    Clicked="OnExitClicked"/>
        </VerticalStackLayout>

    </Grid>
</ContentPage>