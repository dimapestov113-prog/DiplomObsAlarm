<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DiplomObsAlarm.MainPage"
             BackgroundColor="White">

    <Grid x:Name="GeneralSeter" BackgroundColor="White">
        <Image Source="logo.png" 
               HorizontalOptions="Center" 
               VerticalOptions="Center" 
               Aspect="AspectFit" 
               Grid.Row="1" 
               Grid.RowSpan="2" 
               Grid.Column="1" 
               Grid.ColumnSpan="2"/>

        <Label TextColor="Black" 
            Text="ObsAlarM" 
               HorizontalOptions="Center" 
               VerticalOptions="Center" 
               FontAttributes="Bold" 
               FontSize="32" 
               Grid.Column="3" 
               Grid.Row="1" 
               Grid.ColumnSpan="13" 
               Grid.RowSpan="3"/>

        <!-- Подзаголовок -->
        <Label Text="Система экстренного оповещения общежития" 
               HorizontalOptions="Center" 
               VerticalOptions="Center" 
               FontSize="16" 
               TextColor="#666666"
               Grid.Column="2" 
               Grid.Row="3" 
               Grid.ColumnSpan="15" 
               Grid.RowSpan="4" 
               HorizontalTextAlignment="Center"/>

        <!-- Кнопка "Я студент" (черная) -->
        <Border BackgroundColor="#1A1A1A" 
                Stroke="Transparent"
                Grid.Column="1" 
                Grid.Row="7" 
                Grid.ColumnSpan="17" 
                Grid.RowSpan="4"
                Padding="0"
                HorizontalOptions="Fill"
                VerticalOptions="Fill">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnUserClicked"/>
            </Border.GestureRecognizers>

            <!-- Центрирование содержимого внутри ячеек -->
            <VerticalStackLayout HorizontalOptions="Center" 
                                 VerticalOptions="Center"
                                 Spacing="2">
                <Label Text="Я студент" 
                       TextColor="White" 
                       FontAttributes="Bold" 
                       FontSize="16"
                       HorizontalOptions="Center"/>
                <Label Text="Получать уведомления" 
                       TextColor="#AAAAAA" 
                       FontSize="12"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Border>

        <!-- Кнопка "Я администратор" (белая с обводкой) -->
        <Border BackgroundColor="White" 
                Stroke="#1A1A1A"
                StrokeThickness="1.5"
                Grid.Column="1" 
                Grid.Row="12" 
                Grid.ColumnSpan="17" 
                Grid.RowSpan="4"
                Padding="0"
                HorizontalOptions="Fill"
                VerticalOptions="Fill">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnAdminClicked"/>
            </Border.GestureRecognizers>

            <!-- Центрирование содержимого внутри ячеек -->
            <VerticalStackLayout HorizontalOptions="Center" 
                                 VerticalOptions="Center"
                                 Spacing="2">
                <Label Text="Я администратор" 
                       TextColor="#1A1A1A" 
                       FontAttributes="Bold" 
                       FontSize="16"
                       HorizontalOptions="Center"/>
                <Label Text="Отправлять тревоги" 
                       TextColor="#666666" 
                       FontSize="12"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>